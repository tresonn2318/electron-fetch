{
  "name": "@egoist/electron-fetch-example",
  "private": true,
  "scripts": {
    "build": "bun run build:main && bun run build:renderer",
    "build:main": "bun build ./src/main.ts ./src/preload.ts --format=cjs --outdir ./dist --target=node --external electron",
    "build:renderer": "bun build ./src/renderer.ts --outdir ./dist --target=browser --sourcemap",
    "dev": "bun run build && electron ./dist/main.js",
    "smoke": "bun run build && ELECTRON_FETCH_SMOKE_TEST=1 electron ./dist/main.js",
    "typecheck": "bunx tsc --project ./tsconfig.json --noEmit"
  },
  "dependencies": {
    "electron": "40.0.8"
  }
}
